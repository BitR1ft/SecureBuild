# SecureBuild Environment Variables
# Copy this file to .env and fill in the values

# GitHub Integration
GITHUB_TOKEN=          # GitHub Personal Access Token (repo:status, pull_requests:write scopes)

# CVE Database API Keys
NVD_API_KEY=           # NVD API key from https://nvd.nist.gov/developers/request-an-api-key
OSV_API_URL=https://api.osv.dev/v1/query

# SecureBuild Settings
SECUREBUILD_THRESHOLD=7.0    # Score threshold for blocking
FLASK_SECRET_KEY=            # Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
DB_PATH=data/securebuild.db  # Path to SQLite database

# Optional: Slack Notifications
SLACK_WEBHOOK_URL=

# Optional: Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
